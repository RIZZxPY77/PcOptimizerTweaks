<Window x:Class="PCOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PCOptimizer"
        xmlns:views="clr-namespace:PCOptimizer.Views"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="CLAYX-TEAM OPTIMIZE" Height="820" Width="1280"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanMinimize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    
    <Border CornerRadius="10" Background="#0A0D14" BorderBrush="#202D4F" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom title bar area -->
            <Grid Grid.Row="0" Background="#0A0D14" Height="34" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <!-- App Title Text -->
                <TextBlock x:Name="TitleBarText" Text="CLAYX-TEAM OPTIMIZE" FontSize="10.5" FontWeight="Bold" Foreground="#8F9CAE" VerticalAlignment="Center" Margin="16,0,0,0" IsHitTestVisible="False"/>
                
                <!-- HONE-style GAME MODE ON pill badge on the right -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,60,0" IsHitTestVisible="False">
                    <Border Background="#122A1E" BorderBrush="#00E676" BorderThickness="1" CornerRadius="10" Padding="8,2.5">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="5.5" Height="5.5" Fill="#00E676" VerticalAlignment="Center"/>
                            <TextBlock Text="GAME MODE ON" FontSize="8.5" FontWeight="Bold" Foreground="White" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Custom Close Button ONLY -->
                <Button x:Name="CustomCloseBtn" Click="DoNothing" Width="46" Height="34" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                            <Path x:Name="Icon" Data="M 0,0 L 10,10 M 10,0 L 0,10" Stroke="White" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#E81123"/>
                                                <Setter TargetName="Icon" Property="Stroke" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Navigation View and Toast Overlay Container -->
            <Grid Grid.Row="1">
                <!-- Navigation View -->
                <ui:NavigationView x:Name="RootNavigation"
                                   PaneDisplayMode="Top"
                                   IsBackButtonVisible="Collapsed"
                                   Background="#0A0D14"
                                   Margin="0,-8,0,0">
                    <ui:NavigationView.PaneHeader>
                        <Grid Margin="16,4,16,4" Height="36" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Brand Icon -->
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="5" Background="{StaticResource HoneOrangeBrush}" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="Flash24" Filled="True" FontSize="14" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Brand Name -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="CLAYX" FontWeight="Bold" FontSize="13" Foreground="White"/>
                                <TextBlock Text=" OPTIMIZE" FontWeight="Light" FontSize="13" Foreground="#FF9100"/>
                            </StackPanel>
                        </Grid>
                    </ui:NavigationView.PaneHeader>
                    <ui:NavigationView.MenuItems>
                        <ui:NavigationViewItem Content="Dasbor" Icon="Home24" TargetPageType="{x:Type views:DashboardPage}" Tag="dashboard" />
                        <ui:NavigationViewItem Content="PC Optimizer" Icon="Flash24" TargetPageType="{x:Type views:OptimizerPage}" Tag="optimizer" />
                        <ui:NavigationViewItem Content="Game Booster" Icon="Games24" TargetPageType="{x:Type views:GameModePage}" Tag="game_booster" />
                        <ui:NavigationViewItem Content="Mouse &amp; Keyboard" Icon="Keyboard24" TargetPageType="{x:Type views:MouseKeyboardPage}" Tag="mouse_keyboard" />
                        <ui:NavigationViewItem Content="Emulator Gaming" Icon="DeviceEq24" TargetPageType="{x:Type views:EmulatorPage}" Tag="emulator" />
                        <ui:NavigationViewItem Content="Manajer Startup" Icon="ArrowRight24" TargetPageType="{x:Type views:StartupPage}" Tag="startup" />
                        <ui:NavigationViewItem Content="Profil" Icon="Person24" TargetPageType="{x:Type views:ProfilePage}" Tag="profile" />

                        <ui:NavigationViewItem Content="About" Icon="Info24" TargetPageType="{x:Type views:AboutPage}" Tag="about" />
                    </ui:NavigationView.MenuItems>
                </ui:NavigationView>

                <!-- Custom Toast Notification Panel -->
                <Border x:Name="NotificationToast" Width="300" Height="65" Background="#111625" BorderBrush="#00F2FE" BorderThickness="1" CornerRadius="6" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,24,80" Padding="14,10" Visibility="Collapsed" Opacity="0">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="ToastTranslate" Y="50"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon x:Name="ToastIcon" Symbol="CheckmarkCircle24" Filled="True" FontSize="24" Foreground="#00E676" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock x:Name="ToastTitle" Text="Optimasi Sukses" FontSize="11.5" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="ToastMsg" Text="RAM Cache berhasil dibersihkan!" FontSize="9.5" Foreground="#8F9CAE" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
