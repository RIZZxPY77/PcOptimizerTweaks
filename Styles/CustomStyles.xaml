<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <!-- Deep Dark Theme Palettes -->
    <Color x:Key="DeepBgColor">#0A0D14</Color>
    <Color x:Key="CardBgColor">#111625</Color>
    <Color x:Key="AccentColor">#FF9100</Color>
    <Color x:Key="CyanAccentColor">#00F2FE</Color>
    <Color x:Key="GrayTextColor">#8F9CAE</Color>

    <SolidColorBrush x:Key="DeepBgBrush" Color="{StaticResource DeepBgColor}" />
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="CyanAccentBrush" Color="{StaticResource CyanAccentColor}" />
    <SolidColorBrush x:Key="GrayTextBrush" Color="{StaticResource GrayTextColor}" />

    <!-- Override WPF-UI Accent Colors to Match Brand Orange -->
    <Color x:Key="SystemAccentColor">#FF9100</Color>
    <Color x:Key="SystemAccentColorPrimary">#FF9100</Color>
    <Color x:Key="SystemAccentColorSecondary">#FF6F00</Color>
    <Color x:Key="SystemAccentColorTertiary">#FFB300</Color>

    <SolidColorBrush x:Key="SystemAccentBrush" Color="{StaticResource SystemAccentColor}" />
    <SolidColorBrush x:Key="SystemAccentBrushPrimary" Color="{StaticResource SystemAccentColorPrimary}" />
    <SolidColorBrush x:Key="SystemAccentBrushSecondary" Color="{StaticResource SystemAccentColorSecondary}" />
    <SolidColorBrush x:Key="SystemAccentBrushTertiary" Color="{StaticResource SystemAccentColorTertiary}" />

    <!-- Override NavigationView Theme Brushes for complete color consistency -->
    <SolidColorBrush x:Key="NavigationViewPaneBackground" Color="#0A0D14" />
    <SolidColorBrush x:Key="NavigationViewHeaderBackground" Color="#0A0D14" />
    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="#0A0D14" />
    <SolidColorBrush x:Key="NavigationViewBackground" Color="#0A0D14" />
    <SolidColorBrush x:Key="NavigationViewBorderBrush" Color="#0A0D14" />
    <SolidColorBrush x:Key="NavigationViewPaneBorderBrush" Color="#0A0D14" />
    <SolidColorBrush x:Key="NavigationViewHeaderBorderBrush" Color="#0A0D14" />
    <SolidColorBrush x:Key="NavigationViewSeparatorBackground" Color="#0A0D14" />

    <!-- Item states -->
    <SolidColorBrush x:Key="NavigationViewItemHoverBackground" Color="#1C2233" />
    <SolidColorBrush x:Key="NavigationViewItemActiveBackground" Color="#222B40" />
    <SolidColorBrush x:Key="NavigationViewItemActiveBorderBrush" Color="#FF9100" />

    <!-- Global modern font rules -->
    <Style TargetType="{x:Type Control}">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Arial" />
    </Style>
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Arial" />
    </Style>

    <!-- Global Page Styling -->
    <Style TargetType="{x:Type Page}">
        <Setter Property="Background" Value="#0A0D14"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- Modern ScrollBar Styling (Thin, dark, glowing on hover) -->
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid x:Name="Bg" SnapsToDevicePixels="true">
                        <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Focusable="false" Opacity="0" Background="Transparent" BorderBrush="Transparent"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Focusable="false" Opacity="0" Background="Transparent" BorderBrush="Transparent"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb x:Name="Thumb">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                            <Border x:Name="ThumbBorder" Background="#282F42" CornerRadius="4" SnapsToDevicePixels="True"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbBorder" Property="Background" Value="#FF9100"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Premium ListBoxItem & ListViewItem styling (removes Windows blue overrides) -->
    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="Bd" Property="Background" Value="#1B2233"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#2A354D"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="true">
                            <Setter TargetName="Bd" Property="Background" Value="#222B40"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#FF9100"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ListViewItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListViewItem}">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="Bd" Property="Background" Value="#1B2233"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#2A354D"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="true">
                            <Setter TargetName="Bd" Property="Background" Value="#222B40"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#FF9100"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Custom NavigationViewItem style for consistent typography -->
    <Style TargetType="{x:Type ui:NavigationViewItem}" BasedOn="{StaticResource {x:Type ui:NavigationViewItem}}">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Arial" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="#8F9CAE" />
        <Setter Property="Margin" Value="4,2,4,2" />
        <Setter Property="MinHeight" Value="38" />
        <Style.Triggers>
            <Trigger Property="IsActive" Value="True">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Premium Card Gradients -->
    <LinearGradientBrush x:Key="CardNormalGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#161B2B" Offset="0"/>
        <GradientStop Color="#0E121E" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="CardHoverGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1D243A" Offset="0"/>
        <GradientStop Color="#121727" Offset="1"/>
    </LinearGradientBrush>

    <!-- RUN Button style inside feature cards -->
    <Style x:Key="RunCardButtonStyle" TargetType="Border">
        <Setter Property="Background" Value="#FF9100"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FFAB40"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Premium Glow Card Style -->
    <Style x:Key="GlowCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardNormalGradient}" />
        <Setter Property="BorderBrush" Value="#1F2840" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#FF9100" />
                <Setter Property="Background" Value="{StaticResource CardHoverGradient}" />
            </Trigger>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.02" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.02" Duration="0:0:0.15"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.0" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.0" Duration="0:0:0.15"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- Linear Gradient Brushes -->
    <LinearGradientBrush x:Key="HoneOrangeBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFB300" Offset="0" />
        <GradientStop Color="#FF6F00" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CyanBlueBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00F2FE" Offset="0" />
        <GradientStop Color="#4FACFE" Offset="1" />
    </LinearGradientBrush>

    <!-- Action Button Style (Orange Hone-Style) -->
    <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource HoneOrangeBrush}" />
        <Setter Property="Foreground" Value="Black" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Height" Value="40" />
        <Style.Resources>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="6" />
            </Style>
        </Style.Resources>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.9" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Outline Button Style -->
    <Style x:Key="OutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="#323C52" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="#8F9CAE" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Height" Value="40" />
        <Style.Resources>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="6" />
            </Style>
        </Style.Resources>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#FF9100" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Header Text Style -->
    <Style x:Key="HeaderTextPageStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <!-- Subtitle Text Style -->
    <Style x:Key="SubtitleTextPageStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#8F9CAE" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!-- Category Tab RadioButton Style (Modern under-lined style) -->
    <Style x:Key="CategoryTabStyle" TargetType="{x:Type RadioButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#8F9CAE"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <Border x:Name="TabBorder" Background="{TemplateBinding Background}" BorderThickness="0,0,0,2" BorderBrush="Transparent" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#FF9100"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
