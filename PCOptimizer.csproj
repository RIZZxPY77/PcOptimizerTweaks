<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows7.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Management" Version="10.0.8" />
    <PackageReference Include="WPF-UI" Version="4.3.0" />
    <PackageReference Include="LiveCharts.Wpf" Version="0.9.7" />
    <PackageReference Include="MaterialDesignThemes" Version="4.2.1" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="Obfuscar" Version="2.2.38" PrivateAssets="all" />
  </ItemGroup>

  <PropertyGroup>
    <PublishSingleFile>false</PublishSingleFile>
    <SelfContained>false</SelfContained>
    <ApplicationIcon>AhaConvert_[CITYPNG.COM]HD Settings, White Line Icon Transparent Background - 800x800.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Page Remove="Views\PerformancePage.xaml" />
    <Compile Remove="Views\PerformancePage.xaml.cs" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="AhaConvert_[CITYPNG.COM]HD Settings, White Line Icon Transparent Background - 800x800.ico" />
  </ItemGroup>

  <Target Name="ObfuscarTask" AfterTargets="AfterBuild" Condition=" '$(Configuration)' == 'Release' ">
    <ItemGroup>
      <ObfuscarConfig Include="&lt;?xml version='1.0'?&gt;" />
      <ObfuscarConfig Include="&lt;Obfuscator&gt;" />
      <ObfuscarConfig Include="  &lt;Var name='InPath' value='$(ProjectDir)$(OutputPath)' /&gt;" />
      <ObfuscarConfig Include="  &lt;Var name='OutPath' value='$(ProjectDir)$(OutputPath)Obfuscated' /&gt;" />
      <ObfuscarConfig Include="  &lt;Var name='KeepPublicApi' value='false' /&gt;" />
      <ObfuscarConfig Include="  &lt;Var name='HidePrivateApi' value='true' /&gt;" />
      <ObfuscarConfig Include="  &lt;Var name='RenameProperties' value='true' /&gt;" />
      <ObfuscarConfig Include="  &lt;Var name='RenameEvents' value='true' /&gt;" />
      <ObfuscarConfig Include="  &lt;Var name='RenameFields' value='true' /&gt;" />
      <ObfuscarConfig Include="  &lt;Var name='UseUnicodeNames' value='false' /&gt;" />
      <ObfuscarConfig Include="  &lt;Var name='HideStrings' value='true' /&gt;" />
      <ObfuscarConfig Include="  &lt;Var name='OptimizeMethods' value='false' /&gt;" />
      <ObfuscarConfig Include="  &lt;Var name='SuppressIldasm' value='true' /&gt;" />
      <ObfuscarConfig Include="  &lt;AssemblySearchPath path='C:\Program Files\dotnet\shared\Microsoft.WindowsDesktop.App\8.0.27' /&gt;" />
      <ObfuscarConfig Include="  &lt;AssemblySearchPath path='C:\Program Files\dotnet\shared\Microsoft.NETCore.App\8.0.27' /&gt;" />
      <ObfuscarConfig Include="  &lt;Module file='$(ProjectDir)$(OutputPath)PCOptimizer.dll'&gt;" />
      <ObfuscarConfig Include="    &lt;SkipNamespace name='PCOptimizer' /&gt;" />
      <ObfuscarConfig Include="    &lt;SkipNamespace name='PCOptimizer.Views' /&gt;" />
      <ObfuscarConfig Include="    &lt;SkipNamespace name='PCOptimizer.Models' /&gt;" />
      <ObfuscarConfig Include="    &lt;SkipType name='PCOptimizer.Services.SecurityGuard' /&gt;" />
      <ObfuscarConfig Include="    &lt;SkipType name='PCOptimizer.Services.api' /&gt;" />
      <ObfuscarConfig Include="    &lt;SkipType name='PCOptimizer.Services.KeyAuthResponse' /&gt;" />
      <ObfuscarConfig Include="    &lt;SkipType name='PCOptimizer.Services.UserData' /&gt;" />
      <ObfuscarConfig Include="    &lt;SkipType name='PCOptimizer.Services.SubscriptionData' /&gt;" />
      <ObfuscarConfig Include="    &lt;SkipType name='PCOptimizer.Services.LicenseInfo' /&gt;" />
      <ObfuscarConfig Include="    &lt;SkipType name='PCOptimizer.Services.KeyAuthService' /&gt;" />
      <ObfuscarConfig Include="  &lt;/Module&gt;" />
      <ObfuscarConfig Include="&lt;/Obfuscator&gt;" />
    </ItemGroup>
    <WriteLinesToFile File="$(OutputPath)obfuscar_run.xml" Lines="@(ObfuscarConfig)" Overwrite="true" Encoding="utf-8" />
    <Message Importance="high" Text="Running Obfuscar obfuscator with dynamic config: $(OutputPath)obfuscar_run.xml" />
    <Exec Command="&quot;$(Obfuscar)&quot; &quot;$(OutputPath)obfuscar_run.xml&quot;" />
    <Copy SourceFiles="$(OutputPath)Obfuscated\PCOptimizer.dll" DestinationFolder="$(OutputPath)" OverwriteReadOnlyFiles="true" />
  </Target>

  <Target Name="ObfuscarPublishTask" AfterTargets="Publish" Condition=" '$(Configuration)' == 'Release' ">
    <Message Importance="high" Text="Overwriting published DLL with obfuscated version from $(OutputPath)Obfuscated" />
    <Copy SourceFiles="$(OutputPath)Obfuscated\PCOptimizer.dll" DestinationFolder="$(PublishDir)" OverwriteReadOnlyFiles="true" />
  </Target>
