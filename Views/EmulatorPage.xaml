<Page x:Class="PCOptimizer.Views.EmulatorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PCOptimizer.Views"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="850"
      Title="Emulator Mode">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="PageTitleText" Text="Mode Gaming Emulator" Style="{StaticResource HeaderTextPageStyle}" />
            <TextBlock x:Name="PageSubtitleText" Text="Optimasi khusus untuk emulator Android seperti BlueStacks, LDPlayer, GameLoop, dan MSI App Player." Style="{StaticResource SubtitleTextPageStyle}" />
        </StackPanel>

        <!-- Main Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Emulators Grid Launcher-Style -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" x:Name="LeftColumnTitleText" Text="Launcher Emulator Terdeteksi" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

                <ListBox Grid.Row="1" x:Name="EmuListView" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                            </Style.Resources>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource GlowCardStyle}" Margin="4" Padding="14" Height="175" HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Top: Logo, Name & Status Badge -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Background="#1D2E47" HorizontalAlignment="Left" Padding="4">
                                            <ui:SymbolIcon Symbol="{Binding LogoSymbol}" Filled="True" FontSize="20" Foreground="{Binding IconColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                            
                                            <!-- CPU/RAM usage stats when running -->
                                            <StackPanel Orientation="Horizontal" x:Name="StatsPanel">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="CPU: " FontSize="9" Foreground="#8F9CAE"/>
                                                <TextBlock Text="{Binding CpuUsage}" FontSize="9" Foreground="#00E676" FontWeight="SemiBold"/>
                                                <TextBlock Text=" | RAM: " FontSize="9" Foreground="#8F9CAE" Margin="4,0,0,0"/>
                                                <TextBlock Text="{Binding RamUsage}" FontSize="9" Foreground="#00E676" FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <!-- Inactive text -->
                                            <TextBlock x:Name="InactiveTxt" Text="{Binding LocalizedNotRunningText}" FontSize="9" Foreground="#8F9CAE">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
 
                                        <!-- Status Badge -->
                                        <Border Grid.Column="2" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Background" Value="#122A1E"/>
                                                            <Setter Property="BorderBrush" Value="#00E676"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                                            <Setter Property="Background" Value="#222A3C"/>
                                                            <Setter Property="BorderBrush" Value="#323C52"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="8" FontWeight="Bold" Text="{Binding LocalizedStatusText}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Foreground" Value="#00E676"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                                                <Setter Property="Foreground" Value="#8F9CAE"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
 
                                    <!-- Middle: Boost Description -->
                                    <TextBlock Grid.Row="1" Text="{Binding BoostDescription}" FontSize="9.5" Foreground="#8F9CAE" TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="12"/>
 
                                    <!-- Bottom: Optimize Button -->
                                    <Grid Grid.Row="2" VerticalAlignment="Center">
                                        <ui:Button x:Name="OptimizeEmuBtn" Content="{Binding LocalizedOptimizeBtnText}" Tag="{Binding}" Click="OptimizeEmuBtn_Click" Height="28" Padding="12,0" HorizontalAlignment="Stretch">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
 
                                        <ui:Button x:Name="InactiveEmuBtn" Content="{Binding LocalizedInactiveBtnText}" IsEnabled="False" Height="28" Padding="12,0" HorizontalAlignment="Stretch">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource OutlineButtonStyle}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty state placeholder card -->
                <Border Grid.Row="1" x:Name="NoActiveEmulatorCard" Style="{StaticResource GlowCardStyle}" Padding="20" VerticalAlignment="Top" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <ui:SymbolIcon x:Name="NoActiveIcon" Symbol="Info24" Filled="True" FontSize="36" Foreground="#FFC107" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="NoActiveTitleText" Text="TIDAK ADA EMULATOR AKTIF" FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="NoActiveDescText" Text="Tidak ada emulator aktif terdeteksi. Silakan buka emulator Anda (BlueStacks, LDPlayer, GameLoop, dll.) untuk menerapkan optimasi latency dan prioritas CPU secara real-time." FontSize="11" Foreground="#8F9CAE" TextWrapping="Wrap" Margin="0,6,0,0" LineHeight="15"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Settings & BIOS Status Panel (Right column) -->
            <Grid Grid.Column="1" Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- BIOS Virtualization Alert -->
                <Border Grid.Row="0" Style="{StaticResource GlowCardStyle}" Margin="0,0,0,16" VerticalAlignment="Top">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <ui:SymbolIcon x:Name="VirtIcon" Grid.Column="0" Symbol="ShieldCheckmark24" Filled="True" FontSize="36" Foreground="#4CAF50" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="VirtStatusTitle" Text="Virtualisasi BIOS Aktif" FontSize="13.5" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="VirtStatusDesc" Text="Teknologi Intel VT-x/AMD-V sudah diaktifkan. Emulator dapat berjalan dengan performa penuh." FontSize="10" Foreground="#8F9CAE" TextWrapping="Wrap" Margin="0,4,0,0" LineHeight="13"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- GPU Acceleration guide -->
                <Border Grid.Row="1" Style="{StaticResource GlowCardStyle}" VerticalAlignment="Stretch">
                    <StackPanel>
                        <TextBlock x:Name="GpuTitleText" Text="Optimalisasi GPU &amp; Daya" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                        <TextBlock x:Name="GpuDescText" Text="Setiap game di dalam emulator sangat bergantung pada optimalisasi daya kartu grafis (GPU Dedicated) Anda." FontSize="11" Foreground="#8F9CAE" TextWrapping="Wrap" LineHeight="15"/>

                        <Border Background="#1C2E47" BorderBrush="#00F2FE" BorderThickness="1,0,0,0" Padding="12,10" Margin="0,16,0,16" CornerRadius="0,4,4,0">
                            <StackPanel>
                                <TextBlock x:Name="GpuPriorityTitleText" Text="Dedicated GPU Priority" FontSize="10" FontWeight="Bold" Foreground="#00F2FE" Margin="0,0,0,4"/>
                                <TextBlock x:Name="GpuPriorityDescText" Text="Pastikan Anda mengatur pengaturan Windows Graphics ke 'High Performance' untuk file executable emulator player (.exe) Anda agar berjalan di kartu grafis Nvidia/AMD, bukan GPU bawaan Intel/AMD." FontSize="9.5" Foreground="#8F9CAE" TextWrapping="Wrap" LineHeight="13"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#2B1A1E" BorderBrush="#FF1744" BorderThickness="1,0,0,0" Padding="12,10" CornerRadius="0,4,4,0">
                            <StackPanel>
                                <TextBlock x:Name="CpuPolicyTitleText" Text="Physical Core Policy" FontSize="10" FontWeight="Bold" Foreground="#FF1744" Margin="0,0,0,4"/>
                                <TextBlock x:Name="CpuPolicyDescText" Text="Dengan menekan tombol 'OPTIMASI SEKARANG' pada emulator yang aktif, proses emulator akan dikunci untuk hanya berjalan pada physical core CPU, menghindari lag akibat hyperthreading thread sharing." FontSize="9.5" Foreground="#8F9CAE" TextWrapping="Wrap" LineHeight="13"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
