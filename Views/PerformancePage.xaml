<Page x:Class="PCOptimizer.Views.PerformancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:PCOptimizer.Views"
      Title="Performance"
      Background="#0A0D14">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Statistics Panel -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="CPU Usage" FontSize="16" Foreground="White"/>
                <TextBlock x:Name="CpuValue" Text="--%" FontSize="24" FontWeight="Bold" Foreground="#00E676"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="RAM Usage" FontSize="16" Foreground="White"/>
                <TextBlock x:Name="RamValue" Text="--%" FontSize="24" FontWeight="Bold" Foreground="#00E676"/>
            </StackPanel>
        </StackPanel>
        <!-- Simple Chart Placeholder -->
        <Border Grid.Row="1" Background="#111625" CornerRadius="6" Padding="10">
            <Canvas x:Name="ChartCanvas" Height="200" Background="#0A0D14"/>
        </Border>
    </Grid>
</Page>
