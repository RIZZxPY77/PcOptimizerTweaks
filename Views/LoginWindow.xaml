<Window x:Class="PCOptimizer.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Login CLAYX" Height="490" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        ShowInTaskbar="True" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    
    <Border CornerRadius="12" Background="#0A0D14" BorderBrush="#1F2840" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom Drag Bar -->
            <Grid Grid.Row="0" Background="#0A0D14" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="TitleBarText" Text="CLAYX OPTIMIZER LICENSE" FontSize="10.5" FontWeight="Bold" Foreground="#8F9CAE" VerticalAlignment="Center" Margin="16,0,0,0" IsHitTestVisible="False"/>
                <Button x:Name="CloseBtn" Click="CloseBtn_Click" Width="46" Height="32" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                            <Path x:Name="Icon" Data="M 0,0 L 10,10 M 10,0 L 0,10" Stroke="White" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#E81123"/>
                                                <Setter TargetName="Icon" Property="Stroke" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
 
            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="24">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="410">
                    <!-- Brand Logo -->
                    <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource HoneOrangeBrush}" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="Flash24" Filled="True" FontSize="20" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <TextBlock x:Name="BrandTitleText" Text="CLAYX-TEAM OPTIMIZE" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock x:Name="BrandSubText" Text="Aplikasi Premium VIP - Membutuhkan Lisensi Aktif" FontSize="11" Foreground="#FF9100" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,16"/>
 
                    <!-- Warning / Disclaimer Box -->
                    <Border CornerRadius="6" Background="#1C1517" BorderBrush="#E81123" BorderThickness="1" Padding="12" Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Warning24" FontSize="20" Foreground="#E81123" VerticalAlignment="Top" Margin="0,2,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="WarningTitleText" Text="PERINGATAN PENGGUNAAN VIP" FontSize="11" FontWeight="Bold" Foreground="#E81123" Margin="0,0,0,4"/>
                                <TextBlock x:Name="WarningBodyText" Text="Sebelum menggunakan aplikasi, harap ketahui fungsi dari setiap fitur. Tolong jangan asal mengaktifkan fitur tanpa mengetahui masalah spesifik pada PC atau laptop masing-masing untuk menghindari malfungsi sistem." 
                                           FontSize="10.5" Foreground="#D8DEE9" TextWrapping="Wrap" LineHeight="14"/>
                            </StackPanel>
                        </Grid>
                    </Border>
 
                    <TextBlock x:Name="InputLabelText" Text="Masukan Kode Lisensi VIP" FontSize="11.5" FontWeight="SemiBold" Foreground="#8F9CAE" Margin="0,0,0,6"/>
                    
                    <!-- Kode Lisensi VIP -->
                    <ui:TextBox x:Name="KeyTextBox" Text="" Height="36" FontSize="13.5" PlaceholderText="Masukkan Lisensi VIP Anda..." Margin="0,0,0,18" Padding="10,0,10,0" VerticalContentAlignment="Center"/>
 
                    <!-- Login Button -->
                    <ui:Button x:Name="LoginBtn" Content="MASUK KE APLIKASI" Height="38" Style="{StaticResource ActionButtonStyle}" Click="LoginButton_Click" HorizontalAlignment="Stretch" Margin="0,0,0,10"/>
                    
                    <TextBlock x:Name="FooterText" Text="Aplikasi ini bersifat Premium VIP. Hubungi kami untuk membeli lisensi." FontSize="9.5" Foreground="#8F9CAE" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
