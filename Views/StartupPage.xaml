<Page x:Class="PCOptimizer.Views.StartupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PCOptimizer.Views"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Startup Manager">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock x:Name="PageTitleText" Text="Manajer Startup" Style="{StaticResource HeaderTextPageStyle}" />
            <TextBlock x:Name="PageSubtitleText" Text="Nonaktifkan aplikasi startup otomatis untuk mempercepat waktu booting PC Anda." Style="{StaticResource SubtitleTextPageStyle}" />
        </StackPanel>

        <!-- Startup Items List -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListView Grid.Row="0" x:Name="StartupListView" Background="Transparent" BorderThickness="0" Margin="0,0,0,16" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Margin" Value="0,4"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent"/>
                        </Style.Resources>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource GlowCardStyle}" Margin="2" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <Border Grid.Column="0" Width="30" Height="30" CornerRadius="6" Background="#1D2E47" HorizontalAlignment="Left">
                                    <ui:SymbolIcon Symbol="ArrowRight24" Filled="True" FontSize="16" Foreground="#00F2FE" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Name & Command -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="{Binding Command}" FontSize="9" Foreground="#8F9CAE" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Registry Location Info -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,24,0" Width="100">
                                    <TextBlock Text="{Binding RegistryHive}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Registry Run" FontSize="9" Foreground="#8F9CAE"/>
                                </StackPanel>

                                <!-- Impact Badge -->
                                <Border Grid.Column="3" CornerRadius="4" Background="#1D2E47" BorderBrush="{Binding ImpactColor}" BorderThickness="1" Padding="8,4" Margin="0,0,24,0" VerticalAlignment="Center" Width="80">
                                    <TextBlock Text="{Binding LocalizedImpact}" FontSize="9" FontWeight="SemiBold" Foreground="{Binding ImpactColor}" HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Toggle Switch -->
                                <ui:ToggleSwitch Grid.Column="4" IsChecked="{Binding IsEnabled, Mode=TwoWay}" Checked="StartupToggle_Checked" Unchecked="StartupToggle_Unchecked" Content="{Binding EnabledText}" FontSize="11" Foreground="White" VerticalAlignment="Center" Width="100"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Refresh Actions -->
            <ui:Button Grid.Row="1" x:Name="RefreshBtn" Content="PINDAI ULANG STARTUP" Style="{StaticResource ActionButtonStyle}" Click="RefreshBtn_Click" HorizontalAlignment="Stretch" Height="40"/>
        </Grid>
    </Grid>
</Page>
